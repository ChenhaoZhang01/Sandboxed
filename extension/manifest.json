{
  "manifest_version": 3,
  "name": "Sandboxed — Link Detonator",
  "version": "0.3.0",
  "description": "Check links in a sandbox before you visit them — automatically on click, or manually via right-click — and see a risk verdict.",
  "permissions": ["contextMenus", "storage", "tabs", "webNavigation", "downloads", "notifications", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sandboxed — check a link",
    "default_icon": {
      "16": "icons/favicon-32.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-512.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/favicon-32.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-512.png"
  }
}
