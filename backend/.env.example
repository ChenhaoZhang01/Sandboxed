# Copy this file to .env and fill in values. All keys are OPTIONAL.
# The engine works with zero keys (RDAP + DOM heuristics are free and built-in).

# Server
PORT=8787

# Google Safe Browsing API (optional). Free key: https://developers.google.com/safe-browsing
SAFE_BROWSING_API_KEY=

# Gemini API key (optional) — enables the "AI threat report" layer, which writes
# a plain-English summary of the detonation. Without it, that toggle is a no-op.
GEMINI_API_KEY=
# NARRATIVE_MODEL=gemini-2.5-flash
# NARRATIVE_MAX_TOKENS=400
# NARRATIVE_TIMEOUT_MS=20000

# Detonation limits
DETONATE_TIMEOUT_MS=15000
MAX_REDIRECTS=15
SCREENSHOT_DELAY_MS=1500

# Recorded replay (screencast timeline) + credential trap
REPLAY_MAX_FRAMES=30
CREDENTIAL_TRAP_WAIT_MS=3000

# Live interactive sandbox (WebSocket /live). Caps protect the 1GB VM from OOM.
LIVE_MAX_SESSIONS=2
LIVE_IDLE_MS=60000
LIVE_MAX_MS=300000

# ClamAV (clamd) — optional; enables real malware scanning on POST /scan-pdf.
# If clamd isn't reachable, /scan-pdf still works but reports status:"unavailable".
CLAMD_SOCKET=/var/run/clamav/clamd.ctl
CLAMD_HOST=
CLAMD_PORT=3310
CLAM_INIT_TIMEOUT_MS=5000
PDF_SCAN_MAX_MB=20
